# OnlineJourno Platform — environment template
# Copy to .env.local and fill in. Do not commit secrets.

# === Keywords Everywhere (distribution-fit Search cue) ===
# Real search-volume data for the brief's Search-fit cue. Optional: without it
# the brief still composes, just without Search cues. Key from your
# keywordseverywhere.com account.
KEYWORDS_EVERYWHERE_API_KEY=

# === LLM provider (agents-py — ADR 0040) ===
# Bring your own LLM. Default is Anthropic/Claude; a newsroom can point at any
# OpenAI-compatible endpoint, including OpenRouter (→ Gemini/Mistral/Llama/…)
# and self-hosted Ollama / vLLM (no-Big-Tech option).
#
#   LLM_PROVIDER=anthropic                       # or: openai
#   LLM_MODEL=claude-sonnet-4-5                  # any model the provider serves
#   LLM_BASE_URL=                                # openai provider only, e.g.:
#                                                #   Ollama:     http://localhost:11434/v1
#                                                #   vLLM:       http://localhost:8000/v1
#                                                #   OpenRouter: https://openrouter.ai/api/v1
#   LLM_API_KEY=                                 # generic key; falls back to the
#                                                #   provider key below
#   LLM_PRICE_IN=                                # USD per Mtok input  (price an
#   LLM_PRICE_OUT=                               #   unlisted cloud model for the cap)
LLM_PROVIDER=anthropic
LLM_MODEL=
LLM_BASE_URL=
LLM_API_KEY=

# === Anthropic (used when LLM_PROVIDER=anthropic) ===
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-5
ANTHROPIC_CHEAP_MODEL=claude-haiku-4-5
ANTHROPIC_REASONING_MODEL=claude-opus-4-5

# === OpenAI / OpenAI-compatible (used when LLM_PROVIDER=openai) ===
OPENAI_API_KEY=
OPENAI_BASE_URL=

# === Database ===
DATABASE_URL=postgres://localhost:5432/onlinejourno_dev
DATABASE_URL_TEST=postgres://localhost:5432/onlinejourno_test

# === Auth ===
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# === Web app ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PRODUCT_NAME=OnlineJourno

# Privacy-first analytics (Umami) — cookieless, no PII, honors Do-Not-Track.
# Leave both unset to disable (no tracking script renders). Point at your own
# self-hosted Umami: NEXT_PUBLIC_UMAMI_SRC is the script URL, the WEBSITE_ID is
# this site's id from the Umami dashboard.
NEXT_PUBLIC_UMAMI_SRC=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# === Worker ===
WORKER_CONCURRENCY=4
WORKER_LOG_LEVEL=info

# === Module flags (defaults; overridden per newsroom in DB) ===
DEFAULT_MODULES=source-intel,framing-pej

# === Cost caps (USD/day, defaults) ===
DEFAULT_NEWSROOM_DAILY_BUDGET_USD=8
DEFAULT_SHORTLIST_PATH_MAX_DEPTH=2
DEFAULT_BRIEF_PATH_MAX_DEPTH=5
DEFAULT_THREAD_PATH_MAX_CALLS_PER_DAY=20

# === Storage ===
S3_ENDPOINT=
S3_BUCKET=onlinejourno-dev
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ap-south-1
