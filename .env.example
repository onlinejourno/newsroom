# OnlineJourno Platform — environment template
# Copy to .env.local and fill in. Do not commit secrets.

# === Anthropic ===
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-5
ANTHROPIC_CHEAP_MODEL=claude-haiku-4-5
ANTHROPIC_REASONING_MODEL=claude-opus-4-5

# === Database ===
DATABASE_URL=postgres://localhost:5432/onlinejourno_dev
DATABASE_URL_TEST=postgres://localhost:5432/onlinejourno_test

# === Auth ===
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# === Web app ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PRODUCT_NAME=OnlineJourno

# === Worker ===
WORKER_CONCURRENCY=4
WORKER_LOG_LEVEL=info

# === Module flags (defaults; overridden per newsroom in DB) ===
DEFAULT_MODULES=source-intel,framing-pej

# === Cost caps (USD/day, defaults) ===
DEFAULT_NEWSROOM_DAILY_BUDGET_USD=8
DEFAULT_SHORTLIST_PATH_MAX_DEPTH=2
DEFAULT_BRIEF_PATH_MAX_DEPTH=5
DEFAULT_THREAD_PATH_MAX_CALLS_PER_DAY=20

# === Storage ===
S3_ENDPOINT=
S3_BUCKET=onlinejourno-dev
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ap-south-1
