<?xml version="1.0" encoding="UTF-8"?>
<!--
  launchd job: daily brief at 06:30 (local time = IST on the founder's machine).

  Install:
    cp infra/scripts/com.onlinejourno.daily-brief.plist ~/Library/LaunchAgents/
    launchctl unload ~/Library/LaunchAgents/com.onlinejourno.daily-brief.plist 2>/dev/null
    launchctl load   ~/Library/LaunchAgents/com.onlinejourno.daily-brief.plist

  Stop:    launchctl unload ~/Library/LaunchAgents/com.onlinejourno.daily-brief.plist
  Run now: launchctl start com.onlinejourno.daily-brief
  Logs:    /tmp/onlinejourno-daily-brief.{out,err}

  Cost note: ~$0.47/run/day (~Rs 40), within the Rs 2,000/mo cap.
  Edit ProgramArguments path if the repo lives elsewhere.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.onlinejourno.daily-brief</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/ABSOLUTE/PATH/TO/platform/infra/scripts/daily_brief.sh</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>30</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/tmp/onlinejourno-daily-brief.out</string>
    <key>StandardErrorPath</key>
    <string>/tmp/onlinejourno-daily-brief.err</string>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
