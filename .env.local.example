# Arena — local development environment.
#
# Copy this file to `.env` (preferred — read by both Node and Python) or
# to `.env.local` (Next.js-only), then fill in the values. Never commit
# either filled file.

# ============================================================
# Postgres — local dev database
# ============================================================
# Default assumes a local Postgres 15+ instance with the pgvector extension
# and a database named onlinejourno_dev.
DATABASE_URL=postgres://localhost:5432/onlinejourno_dev

# ============================================================
# Anthropic — agent runtime
# ============================================================
# Required only when running shortlist / brief-compose agents. Not needed
# for ingest-only flows.
ANTHROPIC_API_KEY=

# Model routing defaults (overridden per-tenant via cost_budgets row).
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-5
ANTHROPIC_CHEAP_MODEL=claude-haiku-4-5
ANTHROPIC_REASONING_MODEL=claude-opus-4-5

# ============================================================
# Web app
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PRODUCT_NAME=Arena
